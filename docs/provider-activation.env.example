# External provider credentials are inert unless the matching live flag is true.
# Local demo, localhost, and Vercel Preview remain simulated regardless.
# Non-Vercel production must explicitly set CC_ENV=production and a non-local
# APP_ORIGIN. NODE_ENV alone never authorizes provider calls.

# CC_ENV=production
# APP_ORIGIN=https://command-centre.example

PHOTO_MARKETPLACE_LIVE=false
# STRIPE_SECRET_KEY=

STRIPE_BILLING_LIVE=false
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

EMAIL_SEND_LIVE=false
# RESEND_API_KEY=
# EMAIL_FROM=Marketing Command Centre <noreply@example.com>

CC_AI_LIVE=false
# ANTHROPIC_API_KEY=
# CC_AI_MODEL=

PLACES_ENRICHMENT_LIVE=false
# GOOGLE_PLACES_API_KEY=

AUTO_ONBOARDING_LIVE=false
ABN_LOOKUP_LIVE=false
# ABN_LOOKUP_GUID=

PUBLISHING_LIVE=false
# PUBLISHING_TOKEN_KEY=
# META_APP_ID=
# META_APP_SECRET=

ADS_LIVE=false
ANALYTICS_LIVE=false
VISUALS_LIVE=false
LOCAL_SEO_LIVE=false
FUNNEL_LIVE=false
ORDERING_LIVE=false
PARTNER_WEBHOOKS_LIVE=false
