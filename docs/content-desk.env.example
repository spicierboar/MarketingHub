# Command Centre server-only Content Desk authentication
CONTENT_DESK_INTERNAL_TOKEN=replace-with-at-least-32-random-characters
CONTENT_DESK_ACTOR_SIGNING_SECRET=replace-with-a-different-32-byte-or-longer-secret

# Keep managed Content Engine delivery simulated until cutover is approved.
CONTENT_ENGINE_MANAGED_JOBS_LIVE=false
